{
  "name": "roadtrip-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Family Road Trip app backend: event-sourced API server",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test scripts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:scenario": "vitest run --project scenario",
    "validate:specs": "tsx scripts/validate-specs.mjs",
    "simulate": "tsx scripts/simulate-trip.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "build:data": "node scripts/build-data.mjs"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "fastify": "^5.6.2",
    "pg": "^8.16.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "all-the-cities": "^3.1.0",
    "eslint": "^9.30.0",
    "topojson-client": "^3.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "us-atlas": "^3.0.1",
    "vitest": "^3.2.0",
    "word-list": "^4.1.0",
    "yaml": "^2.8.0"
  }
}
